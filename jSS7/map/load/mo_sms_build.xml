        <copy file="${m2.repo}/io/netty/netty-common/4.2.11.Final/netty-common-4.2.11.Final.jar" tofile="${assemble.dir}/netty-common-4.2.11.Final.jar" failonerror="false" />
        <copy file="${m2.repo}/io/netty/netty-buffer/4.2.11.Final/netty-buffer-4.2.11.Final.jar" tofile="${assemble.dir}/netty-buffer-4.2.11.Final.jar" failonerror="false" />
        <copy file="${m2.repo}/io/netty/netty-resolver/4.2.11.Final/netty-resolver-4.2.11.Final.jar" tofile="${assemble.dir}/netty-resolver-4.2.11.Final.jar" failonerror="false" />
        <copy file="${m2.repo}/io/netty/netty-transport/4.2.11.Final/netty-transport-4.2.11.Final.jar" tofile="${assemble.dir}/netty-transport-4.2.11.Final.jar" failonerror="false" />
        <copy file="${m2.repo}/io/netty/netty-transport-native-unix-common/4.2.11.Final/netty-transport-native-unix-common-4.2.11.Final.jar" tofile="${assemble.dir}/netty-transport-native-unix-common-4.2.11.Final.jar" failonerror="false" />
        <copy file="${m2.repo}/io/netty/netty-handler/4.2.11.Final/netty-handler-4.2.11.Final.jar" tofile="${assemble.dir}/netty-handler-4.2.11.Final.jar" failonerror="false" />
        <copy file="${m2.repo}/io/netty/netty-codec/4.2.11.Final/netty-codec-4.2.11.Final.jar" tofile="${assemble.dir}/netty-codec-4.2.11.Final.jar" failonerror="false" />
        <copy file="${m2.repo}/io/netty/netty-codec-base/4.2.11.Final/netty-codec-base-4.2.11.Final.jar" tofile="${assemble.dir}/netty-codec-base-4.2.11.Final.jar" failonerror="false" />
        <copy file="${m2.repo}/io/netty/netty-transport-sctp/4.2.11.Final/netty-transport-sctp-4.2.11.Final.jar" tofile="${assemble.dir}/netty-transport-sctp-4.2.11.Final.jar" failonerror="false" />
        
