        <copy file="${m2.repo}/com/fasterxml/woodstox/woodstox-core/6.5.1/woodstox-core-6.5.1.jar" tofile="${assemble.dir}/woodstox-core-6.5.1.jar" failonerror="false" />
        <copy file="${m2.repo}/org/codehaus/woodstox/stax2-api/4.2.1/stax2-api-4.2.1.jar" tofile="${assemble.dir}/stax2-api-4.2.1.jar" failonerror="false" />
        
        <echo message="Dependencies setup complete!" />
    </target>

    <target name="assemble" description="Builds load tests and assembles binaries." depends="setup-deps">
        <echo message="Java Version: ${java.version}" />
        <echo message="Java home: ${java.home}" />
        <fail message="Unsupported Java version: ${java.version}. Make sure that the version of the Java compiler is 1.7 (7.0) or greater.">
            <condition>
                <not>
                    <or>
                        <contains string="${java.version}" substring="1.7" casesensitive="false" />
                        <contains string="${java.version}" substring="1.8" casesensitive="false" />
                        <matches string="${java.version}" pattern="^11\." />
                        <matches string="${java.version}" pattern="^17\." />
                        <matches string="${java.version}" pattern="^21\." />
                        <matches string="${java.version}" pattern="^25\." />
                    </or>
                </not>
            </condition>
        </fail>

        <!-- Build and install all modules first, then run assembly -->
        <exec executable="${mvn.executable}" dir="${basedir}">
            <arg line="package -DskipTests -Passemble" />
        </exec>
    </target>

    <target name="compile" description="Compile map/load sources to target/classes">
        <mkdir dir="${basedir}/target/classes" />
        <javac srcdir="${basedir}/src/main/java"
               destdir="${basedir}/target/classes"
               classpathref="project.class.path"
               source="${javac.source}"
               target="${javac.source}"
               includeantruntime="false"
               debug="true"
               fork="true" />
    </target>

    <target name="server" description="run the Load Test Server." depends="setup-deps,compile">
        <echo message="${cp.property}" />
        <delete dir="server" failonerror="false" />
        <mkdir dir="server" />
        <delete file="log4j-server.log" failonerror="false" />
        <java classname="${packageprefix}.Server" fork="true" maxmemory="2048m" classpathref="project.class.path" dir="server">
            <jvmarg value="-Dlog.file.name=log4j-server.log" />
            <jvmarg value="-Djboss.server.base.dir=/opt/paic/map-load" />
            <jvmarg value="-Xms2048m"/>
            <jvmarg value="-Xmx2048m"/>
            <jvmarg value="-Xmn128m"/>
            <jvmarg value="-XX:MetaspaceSize=256m"/>
            <jvmarg value="-XX:MaxMetaspaceSize=256m"/>
            <jvmarg value="-XX:+HeapDumpOnOutOfMemoryError"/>
            <!--
            <jvmarg value="-XX:CMSInitiatingOccupancyFraction=80"/>
            <jvmarg value="-XX:+UseConcMarkSweepGC"/>
            <jvmarg value="-XX:+CMSIncrementalMode"/>
            <jvmarg value="-XX:-CMSIncrementalPacing"/>
            <jvmarg value="-XX:CMSIncrementalDutyCycleMin=100"/>
            <jvmarg value="-XX:CMSIncrementalDutyCycle=100"/>
            <jvmarg value="-Dsun.rmi.dgc.client.gcInterval=3600000"/>
            <jvmarg value="-Dorg.jboss.resolver.warning=true"/>
            <jvmarg value="-Djava.net.preferIPv4Stack=true"/>
            <jvmarg value="-Dio.netty.leakDetection.level=advanced"/>
            -->
            <jvmarg value="-XX:+UseParallelGC"/>
            <!-- Java 11: add-opens for XStream to access internal classes -->
            <jvmarg value="--add-opens=java.base/java.lang=ALL-UNNAMED"/>
            <jvmarg value="--add-opens=java.base/java.lang.reflect=ALL-UNNAMED"/>
            <jvmarg value="--add-opens=java.base/java.text=ALL-UNNAMED"/>
            <jvmarg value="--add-opens=java.base/java.util=ALL-UNNAMED"/>
            <jvmarg value="--add-opens=java.base/java.util.concurrent=ALL-UNNAMED"/>
            <jvmarg value="--add-opens=java.base/java.util.concurrent.atomic=ALL-UNNAMED"/>
            <jvmarg value="--add-opens=java.base/java.util.concurrent.locks=ALL-UNNAMED"/>
            <jvmarg value="--add-opens=java.base/java.io=ALL-UNNAMED"/>
            <jvmarg value="--add-opens=java.base/java.nio=ALL-UNNAMED"/>
            <jvmarg value="--add-opens=java.base/java.nio.channels=ALL-UNNAMED"/>
            <jvmarg value="--add-opens=java.base/java.nio.channels.spi=ALL-UNNAMED"/>
            <jvmarg value="--add-opens=java.base/java.security=ALL-UNNAMED"/>
            <jvmarg value="--add-opens=java.base/sun.nio.ch=ALL-UNNAMED"/>
            <!--
            <jvmarg value="-XX:+PrintGCDetails" />
            <jvmarg value="-XX:+PrintGCTimeStamps" />
            -->
            <arg value="${test.server.channelType}" />
            <arg value="${test.server.hostIp}" />
            <arg value="${test.server.hostPort}" />
            <arg value="${test.server.extraHostAddress}" />
            <arg value="${test.server.peerIp}" />
            <arg value="${test.server.peerPort}" />
            <arg value="${test.server.asFunctionality}" />
            <arg value="${test.server.rc}" />
            <arg value="${test.server.na}" />
            <arg value="${test.server.originatingPc}" />
            <arg value="${test.server.destinationPc}" />
            <arg value="${test.server.si}" />
            <arg value="${test.server.ni}" />
            <arg value="${test.server.ssn}" />
            <arg value="${test.server.remoteSsn}" />
            <arg value="64" /> <!-- deliveryTransferMessageThreadCount -->
        </java>
    </target>

    <target name="client" description="run the Load Test Client" depends="setup-deps,compile">
        <echo message="${cp.property}" />
        <delete dir="client" failonerror="false" />
        <mkdir dir="client" />
        <java classname="${packageprefix}.Client" fork="true" maxmemory="2048m" classpathref="project.class.path" dir="client">
