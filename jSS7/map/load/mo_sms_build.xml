        <pathelement location="${assemble.dir}/netty-handler-4.2.11.Final.jar" />
        <pathelement location="${assemble.dir}/netty-codec-4.2.11.Final.jar" />
        <pathelement location="${assemble.dir}/netty-codec-base-4.2.11.Final.jar" />
        <pathelement location="${assemble.dir}/netty-transport-sctp-4.2.11.Final.jar" />
        <pathelement location="${assemble.dir}/jctools-core.jar" />
        <!-- Jackson XML (replaces XStream) -->
        <pathelement location="${assemble.dir}/jackson-dataformat-xml-2.15.2.jar" />
        <pathelement location="${assemble.dir}/jackson-databind-2.15.2.jar" />
        <pathelement location="${assemble.dir}/jackson-core-2.15.2.jar" />
