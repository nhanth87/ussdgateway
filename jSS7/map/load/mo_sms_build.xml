        <copy file="${m2.repo}/com/fasterxml/jackson/dataformat/jackson-dataformat-xml/2.15.2/jackson-dataformat-xml-2.15.2.jar" tofile="${assemble.dir}/jackson-dataformat-xml-2.15.2.jar" failonerror="false" />
        <copy file="${m2.repo}/com/fasterxml/jackson/core/jackson-databind/2.15.2/jackson-databind-2.15.2.jar" tofile="${assemble.dir}/jackson-databind-2.15.2.jar" failonerror="false" />
        <copy file="${m2.repo}/com/fasterxml/jackson/core/jackson-core/2.15.2/jackson-core-2.15.2.jar" tofile="${assemble.dir}/jackson-core-2.15.2.jar" failonerror="false" />
