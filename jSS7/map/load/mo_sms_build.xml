        <pathelement location="${assemble.dir}/stax2-api-4.2.1.jar" />
        <pathelement location="src/main/resources" />
    </path>

    <property name="cp.property" refid="project.class.path" />
    
    <!-- Maven local repository location -->
    <property name="m2.repo" value="${user.home}/.m2/repository" />
    <property name="jss7.root" value="${basedir}/../.." />
    <property name="ethiopia.root" value="${basedir}/../../.." />

    <!-- Target to setup dependencies automatically -->
    <target name="setup-deps" description="Copy all dependencies to target/load">
        <echo message="Setting up dependencies in ${assemble.dir}..." />
        <mkdir dir="${assemble.dir}" />
        
        <!-- Copy project JAR -->
        <copy file="${basedir}/target/map-load-9.2.7.jar" tofile="${assemble.dir}/map-load.jar" failonerror="false" />
        
